# ChatFlow K3s 배포 환경 변수 예시
# 이 파일을 scripts/.env.deploy 로 복사하고 실제 값을 채워넣으세요.
# scripts/.env.deploy 는 .gitignore에 포함되어 있습니다.

# PostgreSQL 패스워드
DEPLOY_DB_PASSWORD=your-db-password-here

# Google Gemini API 키
DEPLOY_GEMINI_API_KEY=your-gemini-api-key-here

# JWT 서명 시크릿 (openssl rand -base64 48 로 생성)
DEPLOY_JWT_SECRET=your-jwt-secret-here

# Gateway 내부 시크릿 (미설정 시 배포 스크립트가 자동 생성)
# 직접 고정값을 지정하려면 주석 해제 (openssl rand -base64 32 로 생성)
# DEPLOY_GATEWAY_SECRET=your-gateway-internal-secret-here

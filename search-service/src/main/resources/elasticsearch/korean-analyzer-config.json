{
  "settings": {
    "index": {
      "max_ngram_diff": 3
    },
    "analysis": {
      "tokenizer": {
        "nori_user_dict": {
          "type": "nori_tokenizer",
          "decompound_mode": "mixed",
          "user_dictionary_rules": [
            "채팅",
            "메시지",
            "실시간",
            "요약",
            "검색"
          ]
        },
        "ngram_tokenizer": {
          "type": "ngram",
          "min_gram": 2,
          "max_gram": 3,
          "token_chars": [
            "letter",
            "digit",
            "punctuation"
          ]
        }
      },
      "filter": {
        "korean_stop": {
          "type": "stop",
          "stopwords": ["이", "그", "저", "것", "들", "및", "등", "의", "에", "를", "을", "는", "은", "가", "이"]
        },
        "korean_synonym": {
          "type": "synonym",
          "synonyms": [
            "채팅,대화,메시지",
            "요약,정리,요약정리",
            "검색,찾기,조회",
            "처방,오더,order",
            "활력징후,바이탈,vital",
            "인수인계,핸드오프,handoff",
            "환자,patient",
            "진단,diagnosis",
            "투약,medication,약물",
            "수술,operation,시술",
            "혈압,BP,blood pressure",
            "맥박,심박수,HR,heart rate",
            "체온,BT,body temperature",
            "호흡,RR,respiratory rate",
            "알러지,알레르기,allergy",
            "응급,긴급,STAT,emergency",
            "경과,progress,경과기록",
            "퇴원,discharge,퇴원요약"
          ]
        }
      },
      "analyzer": {
        "korean_analyzer": {
          "type": "custom",
          "tokenizer": "nori_user_dict",
          "filter": [
            "lowercase",
            "korean_stop",
            "korean_synonym"
          ]
        },
        "korean_ngram_analyzer": {
          "type": "custom",
          "tokenizer": "ngram_tokenizer",
          "filter": [
            "lowercase"
          ]
        },
        "korean_search_analyzer": {
          "type": "custom",
          "tokenizer": "nori_user_dict",
          "filter": [
            "lowercase",
            "korean_stop"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "content": {
        "type": "text",
        "analyzer": "korean_analyzer",
        "search_analyzer": "korean_search_analyzer",
        "fields": {
          "ngram": {
            "type": "text",
            "analyzer": "korean_ngram_analyzer"
          },
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "title": {
        "type": "text",
        "analyzer": "korean_analyzer",
        "search_analyzer": "korean_search_analyzer",
        "fields": {
          "ngram": {
            "type": "text",
            "analyzer": "korean_ngram_analyzer"
          }
        }
      },
      "username": {
        "type": "keyword"
      },
      "chatRoomId": {
        "type": "keyword"
      },
      "userId": {
        "type": "keyword"
      },
      "messageId": {
        "type": "keyword"
      },
      "timestamp": {
        "type": "date"
      },
      "messageType": {
        "type": "keyword"
      },
      "isAiGenerated": {
        "type": "boolean"
      }
    }
  }
}
# ===========================================
# ChatFlow - Environment Variables
# ===========================================
# 이 파일을 복사하여 .env로 저장하고 값을 설정하세요.
# cp .env.example .env

# ------------------------------------------
# [필수] AI Summary Service - Google Gemini
# ------------------------------------------
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------
# [선택] AI 프로바이더 (기본값: spring-ai)
# ------------------------------------------
# application-local.yml 의 spring.profiles.active 에서 설정
# spring-ai    : Spring AI + Google Gemini (기본)
# langchain4j  : LangChain4J + Google Gemini (대안)

# ------------------------------------------
# [선택] Database (기본값 제공)
# ------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatflow_local
DB_USERNAME=chatflow
DB_PASSWORD=chatflow123

# ------------------------------------------
# [선택] Valkey/Redis (기본값 제공)
# ------------------------------------------
VALKEY_HOST=localhost
VALKEY_PORT=6379
# VALKEY_PASSWORD=        # 로컬 환경에서는 비밀번호 불필요

# ------------------------------------------
# [선택] Elasticsearch (기본값 제공)
# ------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=

# ------------------------------------------
# [선택] Kafka (기본값 제공)
# ------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ------------------------------------------
# [선택] Logging (기본값: INFO)
# ------------------------------------------
LOGGING_LEVEL_ROOT=INFO

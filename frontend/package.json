{
  "name": "chatflow-frontend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=23.5.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --build --force",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:pack": "npm run build && electron-builder --config .electron-builder.config.js",
    "electron:dist": "npm run build && electron-builder --config .electron-builder.config.js --publish=never",
    "electron:publish": "npm run build && electron-builder --config .electron-builder.config.js --publish=always"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "pinia": "^2.1.0",
    "bootstrap": "^5.3.0",
    "@popperjs/core": "^2.11.0",
    "axios": "^1.6.0",
    "sockjs-client": "^1.6.0",
    "@stomp/stompjs": "^7.0.0",
    "@vueuse/core": "^10.7.0",
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/sockjs-client": "^1.5.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/tsconfig": "^0.5.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.3.0",
    "electron-window-state": "^5.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.28.0",
    "sass": "^1.79.0",
    "typescript": "~5.5.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0",
    "wait-on": "^7.2.0"
  },
  "main": "electron/main.js",
  "homepage": "./",
  "build": {
    "appId": "com.chatflow.app",
    "productName": "ChatFlow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "icon": "public/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
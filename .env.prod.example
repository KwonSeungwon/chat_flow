# ChatFlow Production Environment Variables
# Copy this file to .env.prod and fill in the values:
#   cp .env.prod.example .env.prod

# ============================================================
# REQUIRED - Must be set before deployment
# ============================================================

# Google Gemini API Key for AI Summary Service
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=chatflow
DB_USER=chatflow

# ============================================================
# OPTIONAL - Defaults are suitable for single-server deployment
# ============================================================

# Spring profile (do not change unless you know what you're doing)
SPRING_PROFILES_ACTIVE=prod

# External access
DOMAIN=localhost
CORS_ALLOWED_ORIGINS=http://localhost

# Kafka
KAFKA_HEAP_OPTS=-Xmx256m -Xms128m

# Elasticsearch
ES_JAVA_OPTS=-Xms256m -Xmx256m

# JVM memory limits per service (tune for your instance size)
GATEWAY_JAVA_OPTS=-Xmx160m -Xms80m -XX:+UseSerialGC -XX:MaxMetaspaceSize=80m
CHAT_JAVA_OPTS=-Xmx160m -Xms80m -XX:+UseSerialGC -XX:MaxMetaspaceSize=80m
AI_SUMMARY_JAVA_OPTS=-Xmx160m -Xms80m -XX:+UseSerialGC -XX:MaxMetaspaceSize=80m
SEARCH_JAVA_OPTS=-Xmx160m -Xms80m -XX:+UseSerialGC -XX:MaxMetaspaceSize=80m
